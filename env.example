# Database Configuration
R2DBC_URL=r2dbc:postgresql://localhost:5432/personal
DB_USER=personal
DB_PASSWORD=personal
FLYWAY_URL=jdbc:postgresql://localhost:5432/personal
FLYWAY_USER=personal
FLYWAY_PASSWORD=personal

# Security
ALLOWED_ORIGINS=http://localhost:3333,http://localhost:3335

# AWS SES Email Configuration
# Region where your SES is configured (e.g., us-east-1, eu-west-1)
AWS_REGION=us-east-1

# AWS Credentials (use IAM user access keys)
# Get these from AWS IAM Console -> Users -> Security credentials
AWS_ACCESS_KEY_ID=AKIA..................
AWS_SECRET_ACCESS_KEY=wJalr..................

# SES Sender Configuration
# This email must be verified in AWS SES
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=My Personal Blog

# Enable/disable email sending (set to false for local dev without SES)
SES_ENABLED=true

# Email Recipients
# Where contact form submissions are sent
ADMIN_EMAIL=your.email@gmail.com

# Email Subject
CONTACT_SUBJECT=New Contact Form Submission

# Application Environment
ENVIRONMENT=dev

